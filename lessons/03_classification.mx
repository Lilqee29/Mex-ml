predict 1
predict 2
predict 3
predict 4
predict 5

## Predict for new tumors
predict 1.5
predict 3.5
predict 4.5

show results
print("")

## ── PART 6: Interpreting Results ────────────────────
##
## Look at the predictions:
##   Size 1 → output near 0 → Benign ✓
##   Size 2 → output near 0 → Benign ✓
##   Size 3 → output near 1 → Malignant ✓
##   Size 4 → output near 1 → Malignant ✓
##   Size 5 → output near 1 → Malignant ✓
##
## The model learned the pattern!
##
## ─────────────────────────────────────────────────────

print("PART 6: Interpreting Results")
print("─────────────────────────────")
print("")

show accuracy

print("")
print("Interpretation:")
print("  Output < 0.5 → Predict 0 (Benign)")
print("  Output ≥ 0.5 → Predict 1 (Malignant)")
print("")

## ── PART 7: Accuracy ───────────────────────────────
##
## Accuracy = how many predictions were correct
##
## If we have 5 test cases and get 4 right:
##   Accuracy = 4/5 = 80%
##
## High accuracy = good model
## Low accuracy = model needs more training or different data
##
## ─────────────────────────────────────────────────────

print("PART 7: Accuracy")
print("────────────────")
print("")

print("Accuracy measures correct predictions:")
print("  Correct predictions / Total predictions")
print("")
print("  80% accuracy = 8 out of 10 correct")
print("  100% accuracy = perfect (rare in real life)")
print("")

