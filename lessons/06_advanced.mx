## ── PART 2: Overfitting ────────────────────────────
##
## OVERFITTING: When a model memorizes data
## instead of learning patterns.
##
## Signs of overfitting:
##   - Training error is LOW
##   - Test error is HIGH
##   - Model works on training data but fails on new data
##
## It's like memorizing answers instead of understanding.
##
## ─────────────────────────────────────────────────────

print("PART 2: Overfitting")
print("────────────────────")
print("")

print("OVERFITTING: Memorizing instead of learning")
print("")
print("Signs:")
print("  - Training error LOW")
print("  - Test error HIGH")
print("  - Fails on new data")
print("")
print("Like memorizing answers vs understanding concepts")
print("")

## ── PART 3: Training vs Test ───────────────────────
##
## To detect overfitting, split data:
##
##   TRAINING SET (80%): Used to train
##   TEST SET (20%): Used to evaluate
##
## If training accuracy > test accuracy → overfitting!
##
## ─────────────────────────────────────────────────────

print("PART 3: Training vs Test")
print("─────────────────────────")
print("")

print("Split data into:")
print("  TRAINING SET (80%): Train the model")
print("  TEST SET (20%): Evaluate performance")
print("")
print("If training accuracy > test accuracy → overfitting!")
print("")

## ── PART 4: Regularization ─────────────────────────
##
## Regularization PREVENTS overfitting by:
##   - Keeping weights small
##   - Reducing complexity
##   - Adding noise during training
##
## Types:
##   L1 Regularization: Adds |weights| to error
##   L2 Regularization: Adds weights² to error
##   Dropout: Randomly disable neurons during training
##
## ─────────────────────────────────────────────────────

print("PART 4: Regularization")
print("───────────────────────")
print("")

print("Regularization PREVENTS overfitting:")
print("")
print("Types:")
print("  L1: Adds |weights| to error")
print("  L2: Adds weights² to error")
print("  Dropout: Randomly disable neurons")
print("")

## ── PART 5: Epochs and Early Stopping ──────────────
##
## Too many epochs → overfitting
## Too few epochs → underfitting
##
## Solution: EARLY STOPPING
##   - Monitor test error
##   - Stop when test error stops improving
##
## ─────────────────────────────────────────────────────

print("PART 5: Epochs and Early Stopping")
print("───────────────────────────────────")
print("")

print("Too many epochs → overfitting")
print("Too few epochs → underfitting")
print("")
print("Solution: EARLY STOPPING")
print("  - Monitor test error")
print("  - Stop when it stops improving")
print("")

## ── PART 6: Model Complexity ───────────────────────
##
## More layers = more complex = can learn harder patterns
## But also = more likely to overfit
##
## Rule of thumb:
##   Simple data → Simple model
##   Complex data → Complex model
##
## ─────────────────────────────────────────────────────

print("PART 6: Model Complexity")
print("─────────────────────────")
print("")

print("More layers = more complex")
print("  + Can learn harder patterns")
print("  - More likely to overfit")
print("")
print("Rule of thumb:")
print("  Simple data → Simple model")
print("  Complex data → Complex model")
print("")

