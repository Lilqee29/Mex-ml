## ── PART 5: Missing Values ─────────────────────────
##
## Real data often has MISSING values.
##
## Options:
##   1. Remove rows with missing values
##   2. Fill with average (mean imputation)
##   3. Fill with 0 or a default
##   4. Use a smarter method (interpolation)
##
## For now, we'll use simple imputation (fill with 0).
##
## ─────────────────────────────────────────────────────

print("PART 5: Missing Values")
print("───────────────────────")
print("")

print("Real data has MISSING values!")
print("")
print("Options:")
print("  1. Remove rows with missing values")
print("  2. Fill with average")
print("  3. Fill with 0")
print("  4. Use interpolation")
print("")

## ── PART 6: Data Types ─────────────────────────────
##
## Real data has different TYPES:
##
##   NUMERICAL: Numbers (age, salary, temperature)
##   CATEGORICAL: Categories (color, city, type)
##
## Categorical data needs ENCODING:
##   Color: Red=0, Blue=1, Green=2
##   Or: Red=[1,0,0], Blue=[0,1,0], Green=[0,0,1]
##
## ─────────────────────────────────────────────────────

print("PART 6: Data Types")
print("───────────────────")
print("")

print("Data types:")
print("  NUMERICAL: Numbers (age, salary)")
print("  CATEGORICAL: Categories (color, city)")
print("")
print("Categorical needs ENCODING:")
print("  Color: Red=0, Blue=1, Green=2")
print("")

## ── PART 7: Practical Example ──────────────────────
##
## Let's work with realistic data:
##   (age, income, hours_studied, passed)
##
## Data:
##   (18, 20000, 2, 0)  — young, low income, studied little, failed
##   (22, 35000, 5, 1)  — young, medium income, studied more, passed
##   (25, 50000, 8, 1)  — young, good income, studied a lot, passed
##   (30, 60000, 3, 0)  — older, good income, studied little, failed
##   (35, 80000, 6, 1)  — older, high income, studied more, passed
##   (40, 90000, 10, 1) — older, high income, studied a lot, passed
##
## ─────────────────────────────────────────────────────

