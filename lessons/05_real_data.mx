## ── PART 1: Real Data is Messy ─────────────────────
##
## So far, we've used clean, perfect data.
## Real data is MESSY!
##
## Problems with real data:
##   - Missing values (empty cells)
##   - Wrong values (typos, errors)
##   - Different scales (age: 0-100, salary: 0-1000000)
##   - Duplicate rows
##   - Extra spaces, wrong formats
##
## ─────────────────────────────────────────────────────

print("═══════════════════════════════════════════════════════")
print("  LESSON 5: Real Data")
print("═══════════════════════════════════════════════════════")
print("")

print("PART 1: Real Data is Messy")
print("───────────────────────────")
print("")

print("So far, we used clean data.")
print("Real data has problems:")
print("  - Missing values")
print("  - Wrong values (typos)")
print("  - Different scales")
print("  - Duplicates")
print("")

## ── PART 2: Data Scales ────────────────────────────
##
## Problem: Features have DIFFERENT SCALES.
##
## Example:
##   Age: 0-100
##   Salary: 0-1,000,000
##
## Salary is 10,000x larger than age!
## The network will think salary is more important.
##
## Solution: NORMALIZE data to same scale (0-1).
##
## ─────────────────────────────────────────────────────

print("PART 2: Data Scales")
print("────────────────────")
print("")

print("Problem: Features have DIFFERENT SCALES")
print("")
print("  Age: 0-100")
print("  Salary: 0-1,000,000")
print("")
print("Salary dominates! Network thinks it's more important.")
print("")

## ── PART 3: Normalization ──────────────────────────
##
## Normalization scales all features to 0-1 range.
##
## Formula:
##   normalized = (value - min) / (max - min)
##
## Example:
##   Age range: 0-100
##   Value 50 → normalized: (50-0)/(100-0) = 0.5
##
## Now all features are on the same scale!
##
## ─────────────────────────────────────────────────────

print("PART 3: Normalization")
print("──────────────────────")
print("")

print("Formula: normalized = (value - min) / (max - min)")
print("")
print("Example:")
print("  Age range: 0-100")
print("  Value 50 → (50-0)/(100-0) = 0.5")
print("  Value 80 → (80-0)/(100-0) = 0.8")
print("")
print("Now all features are 0-1 range!")
print("")

