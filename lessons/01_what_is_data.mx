print("  LESSON 1 COMPLETE!")
print("═══════════════════════════════════════════════════════")
print("")
print("What you learned:")
print("  1. Data has features (inputs) and labels (outputs)")
print("  2. Datasets are collections of examples")
print("  3. Patterns exist in data")
print("  4. We can describe patterns with math")
print("  5. MEX can load and display data")
print("")
print("Next: Lesson 2 — Finding Patterns (Linear Regression)")
