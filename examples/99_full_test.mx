}
print("  sum of 1..5 = " + sum)

## ── STAGE 1: While Loop ────────────────────────────

print("\nSTAGE 1 While Loop:")
let count = 0
while (count < 5) {
  count = count + 1
}
print("  count after while = " + count)

## ── STAGE 1: Functions ─────────────────────────────

print("\nSTAGE 1 Functions:")

fn add(x, y) {
  return x + y
}

fn factorial(n) {
  if (n <= 1) {
    return 1
  }
  return n * factorial(n - 1)
}

fn fibonacci(n) {
  if (n <= 0) {
    return 0
  }
  if (n == 1) {
    return 1
  }
  let a = 0
  let b = 1
  for i in range(2, n + 1) {
    let temp = a + b
    a = b
    b = temp
  }
  return b
}

print("  add(3, 4) = " + add(3, 4))
print("  factorial(5) = " + factorial(5))
print("  fibonacci(10) = " + fibonacci(10))

## ── STAGE 1: Nested Loops ──────────────────────────

print("\nSTAGE 1 Nested Loops:")
let product = 1
for i in range(1, 4) {
  for j in range(1, 4) {
    product = product + 1
  }
}
print("  product = " + product)

## ── STAGE 1: Complex Expressions ───────────────────

print("\nSTAGE 1 Expressions:")
let x = 5
let y = 3
print("  x + y = " + (x + y))
print("  x * y = " + (x * y))
print("  x > y = " + (x > y))
print("  x < y = " + (x < y))
print("  x == 5 = " + (x == 5))
print("  x != 3 = " + (x != 3))
print("  sqrt(pow(x, 2) + pow(y, 2)) = " + sqrt(pow(x, 2) + pow(y, 2)))

