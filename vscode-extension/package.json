{
  "name": "mex-ml-syntax",
  "displayName": "MEX-ML Syntax Highlighting",
  "description": "Syntax highlighting for MEX-ML (.mx) files — a beginner-friendly ML learning language",
  "version": "0.1.0",
  "publisher": "ibrahimqoyum",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "mex-ml",
    "mex",
    "machine learning",
    "syntax highlighting",
    "mx files"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ibrahimqoyum/mex-ml"
  },
  "contributes": {
    "languages": [
      {
        "id": "mx",
        "aliases": [
          "MEX-ML",
          "mx"
        ],
        "extensions": [
          ".mx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mx",
        "scopeName": "source.mx",
        "path": "./syntaxes/mex.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "MEX-ML Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/mex-dark.json"
      }
    ]
  }
}
